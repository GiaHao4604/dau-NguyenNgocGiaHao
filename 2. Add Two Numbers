# Definition for singly-linked list.
# linked lists lưu số thứ tự nguọcws
# class Solution(object):
    def addTwoNumbers(self, l1, l2):
        dummy = ListNode(0)
        node = dummy
        carry = 0  #ghi nhớ số
        while l1 or l2 or carry:
            total = carry
            if l1:
                total += l1.val
                l1 = l1.next
            if l2:
                total += l2.val
                l2 = l2.next
            carry = total // 10
            node.next = ListNode(total % 10)
            node = node.next
        return dummy.next  

