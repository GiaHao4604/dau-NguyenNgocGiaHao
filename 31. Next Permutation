class Solution(object):
    def nextPermutation(self, nums):
        n = len(nums)
        i = n - 2

        # 1. Tìm pivot
        while i >= 0 and nums[i] >= nums[i + 1]:
            i -= 1

        # Nếu tồn tại pivot
        if i >= 0:
            j = n - 1
            # 2. Tìm số lớn hơn pivot bên phải
            while nums[j] <= nums[i]:
                j -= 1
            nums[i], nums[j] = nums[j], nums[i]

        # 3. Reverse suffix
        left, right = i + 1, n - 1
        while left < right:
            nums[left], nums[right] = nums[right], nums[left]
            left += 1
            right -= 1
