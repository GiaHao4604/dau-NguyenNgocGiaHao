class Solution(object):
    def longestValidParentheses(self, s):
        stack = [-1]   # mốc ban đầu
        max_len = 0

        for i, ch in enumerate(s):
            if ch == '(':
                stack.append(i)
            else:
                stack.pop()
                if not stack:
                    stack.append(i)  # mốc mới
                else:
                    max_len = max(max_len, i - stack[-1])

        return max_len
